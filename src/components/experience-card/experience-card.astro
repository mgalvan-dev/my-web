---
import type { ExperienceItem } from "../../models/dictionary.model";
import styles from "./experience-card.module.css";

interface Props {
    dictionary: ExperienceItem;
}

const { dictionary } = Astro.props;
---

<article class={styles.main_container}>
    <a
        href={dictionary.url}
        target="_blank"
        rel="noopener noreferrer"
        class={styles.content_container}
    >
        <div class={styles.info_container}>
            <div class={styles.title_container}>
                <h3 class={styles.title}>{dictionary.title}</h3>
                <p class={styles.working_period}>{dictionary.time}</p>
            </div>
            {
                dictionary.descriptions.map((desc) => (
                    <p class={styles.description}>{desc}</p>
                ))
            }
        </div>
    </a>
</article>
